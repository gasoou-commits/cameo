                </div>
            </div>
        </div>
    </div>

    <!-- 引入 Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        // ==================== 全局配置 ====================
        const config = {
            cameoHost: 'localhost',
            pumaHost: '192.168.1.101',
            incaHost: 'localhost',
            wsPort: 8000,
            clientId: 'web_' + Math.random().toString(36).substr(2, 9)
        };

        let ws = null;
        let isRunning = false;
        let chart = null;
        let reconnectTimer = null;
        let currentTask = null;

        // 历史数据缓存
        const historyData = {
            labels: [],
            speed: [],
            torque: [],
            temp: [],
            maxPoints: 100
        };

        // ==================== 初始化 ====================
        document.addEventListener('DOMContentLoaded', () => {
            initChart();
            loadConfig();
            connectWebSocket();
            updateSystemStatus();
        });

        // ==================== 图表初始化 ====================
        function initChart() {
            const ctx = document.getElementById('realtimeChart').getContext('2d');
            
            chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [
                        {
                            label: '转速 (RPM)',
                            data: [],
                            borderColor: '#60a5fa',
                            backgroundColor: 'rgba(96, 165, 250, 0.1)',
                            borderWidth: 2,
                            tension: 0.4,
                            pointRadius: 0,
                            yAxisID: 'y'
                        },
                        {
                            label: '扭矩 (Nm)',
                            data: [],
                            borderColor: '#4ade80',
                            backgroundColor: 'rgba(74, 222, 128, 0.1)',
                            borderWidth: 2,
                            tension: 0.4,
                            pointRadius: 0,
                            yAxisID: 'y1'
                        },
                        {
                            label: '排温 (°C)',
                            data: [],
                            borderColor: '#fb923c',
                            backgroundColor: 'rgba(251, 146, 60, 0.1)',
                            borderWidth: 2,
                            tension: 0.4,
                            pointRadius: 0,
                            yAxisID: 'y2'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false
                    },
                    plugins: {
                        legend: {
                            labels: { color: '#94a3b8' }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#94a3b8', maxTicksLimit: 10 },
                            grid: { color: '#334155' }
                        },
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            ticks: { color: '#60a5fa' },
                            grid: { color: '#334155' },
                            title: { display: true, text: '转速 (RPM)', color: '#60a5fa' }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            ticks: { color: '#4ade80' },
                            grid: { drawOnChartArea: false },
                            title: { display: true, text: '扭矩 (Nm)', color: '#4ade80' }
                        },
                        y2: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            ticks: { color: '#fb923c' },
                            grid: { drawOnChartArea: false },
                            title: { display: true, text: '温度 (°C)', color: '#fb923c' }
                        }
                    },
                    animation: { duration: 0 }
                }
            });
        }

        // ==================== WebSocket连接 ====================
        function connectWebSocket() {
            if (ws) {
                ws.close();
            }

            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsUrl = `${protocol}//${window.location.hostname}:${config.wsPort}/ws/${config.clientId}`;
            
            updateStatus('wsDot', 'connecting');
            log('正在连接服务器...', 'info');

            ws = new WebSocket(wsUrl);

            ws.onopen = () => {
                updateStatus('wsDot', 'connected');
                log('WebSocket连接成功', 'success');
                
                // 订阅数据频道
                ws.send(JSON.stringify({ action: 'subscribe', channel: 'realtime_data' }));
                ws.send(JSON.stringify({ action: 'subscribe', channel: 'safety_alerts' }));
                ws.send(JSON.stringify({ action: 'subscribe', channel: 'task_status' }));
                ws.send(JSON.stringify({ action: 'subscribe', channel: 'inca_data' }));
                
                // 获取系统状态
                fetchSystemStatus();
            };

            ws.onmessage = (event) => {
                try {
                    const msg = JSON.parse(event.data);
                    handleWebSocketMessage(msg);
                } catch (e) {
                    console.error('消息解析错误:', e);
                }
            };

            ws.onclose = () => {
                updateStatus('wsDot', 'disconnected');
                updateStatus('cameoDot', 'disconnected');
                updateStatus('pumaDot', 'disconnected');
                updateStatus('incaDot', 'disconnected');
                log('连接断开，5秒后重连...', 'warning');
                
                reconnectTimer = setTimeout(connectWebSocket, 5000);
            };

            ws.onerror = (error) => {
                log('WebSocket错误', 'error');
                console.error(error);
            };
        }

        // ==================== 消息处理 ====================
        function handleWebSocketMessage(msg) {
            // 实时数据更新
            if (msg.engine_speed !== undefined) {
                updateRealtimeData(msg);
            }

            // 安全警报
            if (msg.level && msg.message) {
                showAlert(msg.message, msg.level);
                log(`[安全] ${msg.message}`, msg.level === 'critical' ? 'error' : 'warning', 'safety');
            }

            // 任务状态
            if (msg.type) {
                handleTaskMessage(msg);
            }
        }

        function updateRealtimeData(data) {
            // 更新指标卡片
            updateMetric('Speed', data.engine_speed, 'RPM');
            updateMetric('Torque', data.engine_torque, 'Nm');
            updateMetric('Temp', data.exhaust_temp, '°C');
            updateMetric('Lambda', data.lambda_val, '');
            updateMetric('NOx', data.nox_ppm || 0, 'ppm');

            // 更新图表数据
            const now = new Date().toLocaleTimeString();
            
            historyData.labels.push(now);
            historyData.speed.push(data.engine_speed);
            historyData.torque.push(data.engine_torque);
            historyData.temp.push(data.exhaust_temp);

            // 限制数据点数量
            if (historyData.labels.length > historyData.maxPoints) {
                historyData.labels.shift();
                historyData.speed.shift();
                historyData.torque.shift();
                historyData.temp.shift();
            }

            // 更新图表
            chart.data.labels = historyData.labels;
            chart.data.datasets[0].data = historyData.speed;
            chart.data.datasets[1].data = historyData.torque;
            chart.data.datasets[2].data = historyData.temp;
            chart.update('none');

            // 安全状态检查
            const cards = {
                'cardTemp': data.exhaust_temp > 800 ? (data.exhaust_temp > 850 ? 'critical' : 'warning') : '',
                'cardLambda': data.lambda_val < 0.8 || data.lambda_val > 1.3 ? 'warning' : ''
            };

            Object.entries(cards).forEach(([id, status]) => {
                const card = document.getElementById(id);
                card.className = 'metric-card ' + status;
            });
        }

        function updateMetric(name, value, unit) {
            const el = document.getElementById('metric' + name);
            if (el && value !== undefined) {
                const oldVal = parseFloat(el.textContent) || 0;
                el.textContent = typeof value === 'number' ? value.toFixed(name === 'Lambda' ? 2 : 0) : value;
                
                // 更新趋势
                const trendEl = document.getElementById('trend' + name);
                if (trendEl && typeof value === 'number') {
                    const diff = value - oldVal;
                    if (Math.abs(diff) > 0.1) {
                        trendEl.innerHTML = diff > 0 ? 
                            '<span class="trend-up">↑ 上升</span>' : 
                            '<span class="trend-down">↓ 下降</span>';
                    }
                }
            }
        }

        function handleTaskMessage(msg) {
            switch(msg.type) {
                case 'cameo_setup':
                    log(`[CAMEO] ${msg.message}`, 'info', 'cameo');
                    updateProgress(10, 'CAMEO自动搭建试验程序...');
                    break;
                    
                case 'point_change':
                    log(`[PUMA] 切换工况: ${msg.target.speed}rpm @ ${msg.target.torque}Nm`, 'info', 'puma');
                    updateProgress(null, `切换至 ${msg.target.speed}rpm...`);
                    break;
                    
                case 'stabilized':
                    log(`[PUMA] 工况稳定: ${msg.point.speed}rpm`, 'success', 'puma');
                    updateProgress(null, '工况已稳定，开始测量...');
                    break;
                    
                case 'point_completed':
                    addResultRow(msg);
                    const percent = Math.round(((msg.index + 1) / msg.total) * 100);
                    updateProgress(percent, `已完成 ${msg.index + 1}/${msg.total} 个工况点`);
                    break;
                    
                case 'inca_data':
                    log(`[INCA] 标定数据已同步: ${Object.keys(msg.data || {}).length} 个变量`, 'info', 'inca');
                    break;
                    
                case 'task_complete':
                    isRunning = false;
                    document.getElementById('startBtn').disabled = false;
                    document.getElementById('stopBtn').disabled = true;
                    updateProgress(100, '测试完成');
                    log('测试任务全部完成', 'success');
                    showAlert('测试任务已完成！', 'success');
                    break;
                    
                case 'error':
                    log(`[错误] ${msg.message}`, 'error');
                    showAlert(msg.message, 'critical');
                    break;
            }
        }

        // ==================== 任务控制 ====================
        async function startTask() {
            const description = document.getElementById('taskInput').value.trim();
            if (!description) {
                showAlert('请输入测试需求描述', 'warning');
                return;
            }

            // 模拟AI解析（实际应调用后端API）
            const plan = parseTestPlan(description);
            showPlanPreview(plan);

            // 显示进度区域
            document.getElementById('progressSection').style.display = 'block';
            document.getElementById('resultsPanel').style.display = 'block';
            document.getElementById('startBtn').disabled = true;
            document.getElementById('stopBtn').disabled = false;
            isRunning = true;

            log('[AI] 解析测试需求...', 'info', 'ai');
            log(`[AI] 生成测试计划: ${plan.points.length} 个工况点`, 'info', 'ai');

            // 模拟发送任务到后端
            setTimeout(() => {
                log('[系统] 任务已提交到执行队列', 'success');
                simulateTaskExecution(plan);
            }, 1000);
        }

        function parseTestPlan(description) {
            // 简单的自然语言解析逻辑
            const plan = {
                name: `Test_${Date.now()}`,
                engine_model: 'Diesel_2.0L',
                points: [],
                safety_limits: { max_exhaust_temp: 850, max_torque: 500, min_lambda: 0.8 },
                inca_variables: ['InjectionTiming', 'RailPressure', 'EGRRate', 'LambdaSetpoint']
            };

            // 解析转速范围
            const speedMatch = description.match(/(\d+)\s*到\s*(\d+)\s*转/);
            if (speedMatch) {
                const start = parseInt(speedMatch[1]);
                const end = parseInt(speedMatch[2]);
                const step = description.includes('每500') ? 500 : 250;
                
                for (let speed = start; speed <= end; speed += step) {
                    plan.points.push({
                        speed: speed,
                        torque: description.includes('全负荷') ? 400 : 200,
                        duration: 30,
                        stabilization: 30
                    });
                }
            } else {
                // 默认测试点
                plan.points = [
                    { speed: 1500, torque: 400, duration: 30, stabilization: 30 },
                    { speed: 2000, torque: 400, duration: 30, stabilization: 30 },
                    { speed: 2500, torque: 400, duration: 30, stabilization: 30 },
                    { speed: 3000, torque: 400, duration: 30, stabilization: 30 },
                    { speed: 3500, torque: 400, duration: 30, stabilization: 30 },
                    { speed: 4000, torque: 400, duration: 30, stabilization: 30 }
                ];
            }

            return plan;
        }

        function showPlanPreview(plan) {
            const preview = document.getElementById('planPreview');
            const content = document.getElementById('planContent');
            
            const html = `
                <div style="margin-bottom: 10px;"><strong>发动机型号:</strong> ${plan.engine_model}</div>
                <div style="margin-bottom: 10px;"><strong>测试点数:</strong> ${plan.points.length} 个</div>
                <div style="margin-bottom: 10px;"><strong>转速范围:</strong> ${plan.points[0].speed} - ${plan.points[plan.points.length-1].speed} RPM</div>
                <div style="margin-bottom: 10px;"><strong>测量变量:</strong> ${plan.inca_variables.join(', ')}</div>
                <div><strong>安全限制:</strong> 排温≤${plan.safety_limits.max_exhaust_temp}°C, 扭矩≤${plan.safety_limits.max_torque}Nm</div>
            `;
            
            content.innerHTML = html;
            preview.style.display = 'block';
        }

        function simulateTaskExecution(plan) {
            // 模拟任务执行过程
            let currentIndex = 0;
            
            function executeNextPoint() {
                if (!isRunning || currentIndex >= plan.points.length) {
                    if (isRunning) {
                        handleTaskMessage({ type: 'task_complete' });
                    }
                    return;
                }

                const point = plan.points[currentIndex];
                
                // 发送工况切换消息
                handleTaskMessage({
                    type: 'point_change',
                    target: point
                });

                // 模拟工况切换过程
                let stableTime = 0;
                const stableInterval = setInterval(() => {
                    if (!isRunning) {
                        clearInterval(stableInterval);
                        return;
                    }

                    // 模拟实时数据
                    const progress = stableTime / 10; // 10步达到稳定
                    const currentSpeed = point.speed + (Math.random() - 0.5) * 20 * (1 - progress);
                    const currentTorque = point.torque + (Math.random() - 0.5) * 10 * (1 - progress);
                    
                    updateRealtimeData({
                        engine_speed: currentSpeed,
                        engine_torque: currentTorque,
                        exhaust_temp: 400 + (point.torque / 500) * 300 + Math.random() * 20,
                        lambda_val: 1.0 + (Math.random() - 0.5) * 0.1,
                        nox_ppm: 150 + Math.random() * 50
                    });

                    stableTime++;
                    
                    if (stableTime >= 10) {
                        clearInterval(stableInterval);
                        
                        // 发送稳定消息
                        handleTaskMessage({
                            type: 'stabilized',
                            point: point
                        });

                        // 模拟测量过程
                        setTimeout(() => {
                            // 发送完成消息
                            handleTaskMessage({
                                type: 'point_completed',
                                index: currentIndex,
                                total: plan.points.length,
                                data: {
                                    point: point,
                                    measurement_file: `measurement_${point.speed}rpm_${Date.now()}.mdf`,
                                    inca_data: {
                                        InjectionTiming: 15.5 + Math.random(),
                                        RailPressure: 1200 + Math.random() * 100,
                                        EGRRate: 15 + Math.random() * 5
                                    }
                                }
                            });

                            currentIndex++;
                            setTimeout(executeNextPoint, 1000);
                        }, point.duration * 100); // 加速模拟
                    }
                }, 200);
            }

            // 开始执行
            handleTaskMessage({ type: 'cameo_setup', message: '正在自动配置测量通道和试验序列...' });
            setTimeout(executeNextPoint, 2000);
        }

        function stopTask() {
            if (!confirm('确定要紧急停止当前任务吗？这将立即中断测试并保存已收集的数据。')) {
                return;
            }
            
            isRunning = false;
            log('[系统] 紧急停止已触发！', 'error', 'safety');
            showAlert('任务已紧急停止', 'critical');
            
            document.getElementById('startBtn').disabled = false;
            document.getElementById('stopBtn').disabled = true;
            updateProgress(0, '已停止');
        }

        // ==================== 结果显示 ====================
        function addResultRow(msg) {
            const tbody = document.getElementById('resultsTable');
            const row = document.createElement('tr');
            const data = msg.data;
            
            row.innerHTML = `
                <td>${msg.index + 1}</td>
                <td>${data.point.speed}</td>
                <td>${data.point.torque}</td>
                <td>${data.point.duration}s</td>
                <td><code>${data.measurement_file}</code></td>
                <td>
                    <div style="font-size: 0.8rem;">
                        IT: ${data.inca_data.InjectionTiming.toFixed(2)}°<br>
                        RP: ${data.inca_data.RailPressure.toFixed(0)}bar<br>
                        EGR: ${data.inca_data.EGRRate.toFixed(1)}%
                    </div>
                </td>
                <td><span class="badge badge-completed">完成</span></td>
                <td>
                    <button class="btn btn-secondary" style="width: auto; padding: 6px 12px; font-size: 0.8rem;" onclick="downloadData('${data.measurement_file}')">
                        下载
                    </button>
                </td>
            `;
            
            tbody.appendChild(row);
        }

        function downloadData(filename) {
            log(`[系统] 准备下载: ${filename}`, 'info');
            showAlert('数据下载功能需要后端支持', 'warning');
        }

        // ==================== 辅助功能 ====================
        function updateProgress(percent, text) {
            if (percent !== null) {
                document.getElementById('progressFill').style.width = percent + '%';
                document.getElementById('progressPercent').textContent = percent + '%';
            }
            if (text) {
                document.getElementById('progressText').textContent = text;
                document.getElementById('currentOperation').textContent = text;
            }
        }

        function updateStatus(id, status) {
            const dot = document.getElementById(id);
            dot.className = 'status-dot ' + status;
        }

        function showAlert(message, level = 'warning') {
            const banner = document.getElementById('alertBanner');
            const content = document.getElementById('alertContent');
            
            content.textContent = message;
            banner.className = 'alert-banner ' + level + ' show';
            
            setTimeout(() => {
                banner.classList.remove('show');
            }, 5000);
        }

        function hideAlert() {
            document.getElementById('alertBanner').classList.remove('show');
        }

        function log(message, type = 'info', tag = '') {
            const container = document.getElementById('logContainer');
            const entry = document.createElement('div');
            entry.className = `log-entry ${type}`;
            
            const time = new Date().toLocaleTimeString();
            const tagHtml = tag ? `<span class="log-tag ${tag}">${tag.toUpperCase()}</span>` : '';
            
            entry.innerHTML = `<span class="log-time">[${time}]</span>${tagHtml}${message}`;
            container.appendChild(entry);
            container.scrollTop = container.scrollHeight;
            
            // 限制日志条目数
            while (container.children.length > 100) {
                container.removeChild(container.firstChild);
            }
        }

        // ==================== 配置管理 ====================
        function toggleConfig() {
            const modal = document.getElementById('configModal');
            modal.classList.toggle('show');
        }

        function loadConfig() {
            const saved = localStorage.getItem('aiEngineConfig');
            if (saved) {
                Object.assign(config, JSON.parse(saved));
                document.getElementById('cameoHost').value = config.cameoHost;
                document.getElementById('pumaHost').value = config.pumaHost;
                document.getElementById('incaHost').value = config.incaHost;
                document.getElementById('wsPort').value = config.wsPort;
            }
        }

        function saveConfig() {
            config.cameoHost = document.getElementById('cameoHost').value;
            config.pumaHost = document.getElementById('pumaHost').value;
            config.incaHost = document.getElementById('incaHost').value;
            config.wsPort = parseInt(document.getElementById('wsPort').value);
            
            localStorage.setItem('aiEngineConfig', JSON.stringify(config));
            toggleConfig();
            log('配置已保存，重新连接...', 'info');
            connectWebSocket();
        }

        // ==================== 预设模板 ====================
        function setPreset(type) {
            const templates = {
                fullLoad: '测试发动机在1500到4000转，每500转一个点，全负荷特性（最大扭矩），每个点测量30秒，记录排放和燃烧数据',
                partLoad: '测试发动机在1500到3500转，部分负荷（50%扭矩），每250转一个点，每个点测量20秒，重点关注燃油经济性',
                emission: '执行WLTC排放测试循环，记录NOx、HC、CO和颗粒物排放，同步采集燃烧参数',
                transient: '执行瞬态响应测试：从1500转急加速到4000转，记录响应时间和超调量，测量涡轮迟滞'
            };
            
            document.getElementById('taskInput').value = templates[type] || '';
        }

        // ==================== API调用 ====================
        async function fetchSystemStatus() {
            try {
                const response = await fetch(`/api/status`);
                if (response.ok) {
                    const data = await response.json();
                    updateStatus('cameoDot', data.cameo === 'connected' ? 'connected' : 'disconnected');
                    updateStatus('pumaDot', data.puma === 'connected' ? 'connected' : 'disconnected');
                    updateStatus('incaDot', data.inca === 'connected' ? 'connected' : 'disconnected');
                }
            } catch (e) {
                console.error('获取状态失败:', e);
            }
        }

        function updateSystemStatus() {
            // 定期更新系统状态
            setInterval(fetchSystemStatus, 5000);
        }
    </script>
</body>
</html>
