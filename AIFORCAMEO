                <!-- 测试结果 -->
                <div class="panel results-panel" id="resultsPanel" style="display: none;">
                    <div class="panel-header">
                        <span>✅</span>
                        <h2>测试结果</h2>
                    </div>
                    <div class="panel-body">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>序号</th>
                                    <th>转速 (RPM)</th>
                                    <th>扭矩 (Nm)</th>
                                    <th>持续时间</th>
                                    <th>测量文件</th>
                                    <th>INCA数据</th>
                                    <th>状态</th>
                                    <th>操作</th>
